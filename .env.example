# Copy this file to ".env" and fill in your own values. Never commit ".env".

# --- OpenAI (required) ---
OPENAI_API_KEY=sk-...
# Optional overrides:
OPENAI_REALTIME_MODEL=gpt-realtime-2     # voice model
OPENAI_REALTIME_VOICE=shimmer            # voice name
OPENAI_TEXT_AGENT_MODEL=gpt-5.4          # background "expert" agent model

# --- Composio (required for app connections: Gmail, GitHub, …) ---
COMPOSIO_API_KEY=ak_...

# --- Supabase (required for auth) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
SUPABASE_SERVICE_ROLE=your_service_role_key   # server-only; never exposed to the browser

# --- API session cookie (optional) ---
# Signs the HttpOnly cookie that gates the /api routes. Falls back to OPENAI_API_KEY if unset.
APP_API_AUTH_SECRET=long_random_secret

# --- Timeouts (optional, milliseconds) ---
OPENAI_REALTIME_SECRET_TIMEOUT_MS=10000
OPENAI_TEXT_AGENT_TIMEOUT_MS=30000
SEARCH_TIMEOUT_MS=12000
